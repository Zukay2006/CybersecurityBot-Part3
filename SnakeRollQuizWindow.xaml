<Window x:Class="CyberSecurityBotPart2.SnakeRollQuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snake, Roll, Quiz"
        Height="720"
        Width="1100"
        Background="#FFF4E5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF8C00" CornerRadius="15" Padding="15">
            <TextBlock Text="🐍 🎲 SNAKE, ROLL, QUIZ"
                       Foreground="White"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="15" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="🎮 Instructions"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#FF8C00"/>

                    <TextBlock Text="Roll the coding dice.&#x0a;Answer questions correctly to move.&#x0a;Reach square 60 to win.&#x0a;Beware of cyber snakes!"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Margin="0,10"/>

                    <Button x:Name="StartGameButton"
                            Click="StartGameButton_Click"
                            Content="START GAME"
                            Background="#FF8C00"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="16"
                            Height="45"
                            Margin="0,10,0,0"/>

                    <Button x:Name="RollDiceButton"
                            Click="RollDiceButton_Click"
                            Content="ROLL DICE 🎲"
                            Background="#FF8C00"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="16"
                            Height="45"
                            Margin="0,10,0,0"
                            IsEnabled="False"/>

                    <Border x:Name="DiceBox"
                            Background="#FF8C00"
                            CornerRadius="12"
                            Width="120"
                            Height="120"
                            Margin="0,20,0,0"
                            HorizontalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="&lt;C# /&gt;"
               FontSize="18"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"/>

                            <TextBlock x:Name="DiceResultText"
               Text="?"
               FontSize="42"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"/>

                            <TextBlock Text="SQL  JS"
               FontSize="14"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"/>
                        </StackPanel>


                    </Border>

                    <TextBlock x:Name="PositionText"
                               Text="Position: 0 / 60"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>

                    <TextBlock x:Name="ScoreText"
                               Text="Score: 0"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="10">
                <UniformGrid x:Name="BoardGrid"
                             Rows="6"
                             Columns="10"/>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="15"
                Padding="15">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel>
                    <TextBlock x:Name="QuestionText"
                               Text="Click START GAME to begin."
                               FontSize="18"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="55"/>
                            <RowDefinition Height="55"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="OptionAButton"
                                Grid.Column="0"
                                Grid.Row="0"
                                Margin="5"
                                Click="AnswerButton_Click"
                                FontSize="14"
                                IsEnabled="False"/>

                        <Button x:Name="OptionBButton"
                                Grid.Column="1"
                                Grid.Row="0"
                                Margin="5"
                                Click="AnswerButton_Click"
                                FontSize="14"
                                IsEnabled="False"/>

                        <Button x:Name="OptionCButton"
                                Grid.Column="0"
                                Grid.Row="1"
                                Margin="5"
                                Click="AnswerButton_Click"
                                FontSize="14"
                                IsEnabled="False"/>

                        <Button x:Name="OptionDButton"
                                Grid.Column="1"
                                Grid.Row="1"
                                Margin="5"
                                Click="AnswerButton_Click"
                                FontSize="14"
                                IsEnabled="False"/>
                    </Grid>

                    <TextBlock x:Name="FeedbackText"
                               Text=""
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FF8C00"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>

                    <Button x:Name="NextQuestionButton"
                            Content="NEXT QUESTION ▶"
                            Background="#FF8C00"
                            Foreground="White"
                            FontWeight="Bold"
                            FontSize="14"
                            Height="40"
                            Margin="0,10,0,0"
                            Visibility="Collapsed"
                            Click="NextQuestionButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>