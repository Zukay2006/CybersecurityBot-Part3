<Window x:Class="CyberSecurityBotPart2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Assistant"
        Height="650"
        Width="900"
        Background="#FFF4E5"
        Loaded="Window_Loaded">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FF8C00"
                CornerRadius="15"
                Padding="12">

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="(^_^)/"
                           FontSize="42"
                           Margin="10"
                           Foreground="White"/>

                <StackPanel x:Name="TitlePanel"
                            VerticalAlignment="Center"
                            Opacity="0">

                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="TitleDropTransform" Y="-40"/>
                    </StackPanel.RenderTransform>

                    <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="ChatBuddy - Stay Safe Online"
                               FontSize="18"
                               Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
        Background="White"
        CornerRadius="10"
        Margin="0,5"
        Padding="5"> 
            <TextBlock x:Name="MovingBot"
                       Text="🛡️&#x0a;╔════════════╗&#x0a;║  ◉     ◉  ║&#x0a;║     ▔     ║&#x0a;╚════════════╝&#x0a;     /|\&#x0a;    / | \&#x0a;   /  |  \&#x0a;  /___|___\&#x0a;&#x0a;CYBER BOT"
                       FontSize="16"
                       FontWeight="Bold"
                       FontFamily="Consolas"
                       Foreground="#FF8C00"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="2,0,0,0" Height="162" Width="136">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="MovingBotTransform" X="-250"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Border>

        <Border Grid.Row="2"
                Margin="0,10,0,15"
                Background="White"
                CornerRadius="15"
                Padding="10">

            <RichTextBox x:Name="ChatArea"
             FontSize="16"
             IsReadOnly="True"
             VerticalScrollBarVisibility="Auto"
             Background="White"
             BorderThickness="0"/>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
        Background="White"
        CornerRadius="10"
        Margin="5">

                <TextBox x:Name="UserInput"
             FontSize="16"
             Padding="8"
             BorderThickness="0"
             Background="Transparent"/>
            </Border>

            <Button Grid.Column="1"
        x:Name="SendButton"
        Content="SEND"
        Background="#FF8C00"
        Foreground="White"
        FontSize="16"
        FontWeight="Bold"
        Margin="5"
        Click="SendButton_Click"/> 
        </Grid>

    </Grid>
</Window>